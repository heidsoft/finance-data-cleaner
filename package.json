{
  "name": "finance-data-cleaner",
  "version": "1.0.0",
  "description": "财务数据清洗工具 - CSV/Excel处理、去重、合并",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "keywords": [
    "electron",
    "react",
    "data-cleaner",
    "finance"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.15.5",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vite-plugin-node-polyfills": "^0.26.0"
  },
  "build": {
    "appId": "com.finance.datacleaner",
    "productName": "财务数据清洗工具",
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dir",
      "category": "public.app-category.productivity"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  }
